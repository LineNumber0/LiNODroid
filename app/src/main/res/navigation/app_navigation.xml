<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/app_navigation"
    app:startDestination="@id/mainFragment">

    <fragment
        android:id="@+id/mainFragment"
        android:name="ma.oprojet.linodroid.view.fragment.MainFragment"
        android:label="MainFragment" />
    <fragment
        android:id="@+id/detailFragment"
        android:name="ma.oprojet.linodroid.view.fragment.DetailFragment"
        android:label="fragment_detail"
        tools:layout="@layout/fragment_detail" >
        <argument
            android:name="postId"
            app:argType="integer"
            android:defaultValue="0" />
        <action
            android:id="@+id/action_detailFragment_to_commentsFragment"
            app:destination="@id/commentsFragment" />
    </fragment>
    <action
        android:id="@+id/action_global_detailFragment"
        app:destination="@id/detailFragment" />
    <fragment
        android:id="@+id/commentsFragment"
        android:name="ma.oprojet.linodroid.view.fragment.CommentsFragment"
        android:label="fragment_comments"
        tools:layout="@layout/fragment_comments" >
        <argument
            android:name="postId"
            app:argType="integer" />
    </fragment>
    <fragment
        android:id="@+id/SettingsFragment"
        android:name="ma.oprojet.linodroid.view.fragment.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings"/>

        <fragment
            android:id="@+id/AboutFragment"
            android:name="ma.oprojet.linodroid.view.fragment.AboutFragment"
            android:label="About"
            tools:layout="@layout/fragment_about"/>

</navigation>