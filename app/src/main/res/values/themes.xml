<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.LiNODroid" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/brandClr</item>
        <item name="colorPrimaryVariant">@color/brandClrDark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>


        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/StatusBarColor</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Customize your theme here. -->

        <item name="switchPreferenceCompatStyle">@style/CustomSwitchPreference</item>

    </style>

    <style name="CustomSwitchPreference" parent="Preference.SwitchPreferenceCompat">
        <item name="android:thumbTint">@color/switch_thumb_selector</item>
        <item name="android:trackTint">@color/switch_track_selector</item>
    </style>
</resources>